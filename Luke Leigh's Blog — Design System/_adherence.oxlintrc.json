{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/blog/**",
              "components/buttons/**",
              "components/feedback/**",
              "components/identity/**",
              "components/labels/**",
              "jekyll-theme/assets/js/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Exo|Unica One|Lucida Grande|Lucida Console))/i]",
        "message": "Font not provided by the design system. Available: Exo, Unica One, Lucida Grande, Lucida Console."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|url|key|ref|className|style|children)$/]",
        "message": "<SocialLink> doesn't accept that prop. Declared props: label, icon, url."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|success|warning|danger|info|neutral)$/]",
        "message": "<Badge> variant must be one of 'primary' | 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|icon|block|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, icon, block, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|inverse|light-outline|success|warning|danger|info|github|linkedin)$/]",
        "message": "<Button> variant must be one of 'primary' | 'inverse' | 'light-outline' | 'success' | 'warning' | 'danger' | 'info' | 'github' | 'linkedin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large|x-large)$/]",
        "message": "<Button> size must be one of 'small' | 'medium' | 'large' | 'x-large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Masthead'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|title|subtitle|items|current|style|key|ref|className|style|children)$/]",
        "message": "<Masthead> doesn't accept that prop. Declared props: logo, title, subtitle, items, current, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notice'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|title|icon|style|key|ref|className|style|children)$/]",
        "message": "<Notice> doesn't accept that prop. Declared props: children, variant, title, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notice'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|info|warning|success|danger)$/]",
        "message": "<Notice> variant must be one of 'default' | 'primary' | 'info' | 'warning' | 'success' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|readTime|category|items|style|key|ref|className|style|children)$/]",
        "message": "<PageMeta> doesn't accept that prop. Declared props: date, readTime, category, items, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pagination'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|total|onPage|style|key|ref|className|style|children)$/]",
        "message": "<Pagination> doesn't accept that prop. Declared props: current, total, onPage, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|icon|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, href, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeaserCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|href|image|excerpt|date|readTime|category|style|key|ref|className|style|children)$/]",
        "message": "<TeaserCard> doesn't accept that prop. Declared props: title, href, image, excerpt, date, readTime, category, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
